# ============================================
# AutoDeployHub Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# -- General --
NODE_ENV=development
APP_NAME=AutoDeployHub
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# -- Database (PostgreSQL) --
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autodeployhub?schema=public

# -- Redis --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -- JWT --
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=7d

# -- GitHub OAuth --
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# -- AWS --
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_ARTIFACTS_BUCKET=autodeployhub-artifacts
AWS_S3_LOGS_BUCKET=autodeployhub-logs

# -- Encryption --
ENCRYPTION_KEY=your-32-char-encryption-key-here

# -- Worker --
WORKER_CONCURRENCY=5
DOCKER_HOST=unix:///var/run/docker.sock
